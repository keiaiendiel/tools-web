---
/* VariantBase — shared shell for the design-exploration variants (/1../5).
   -----------------------------------------------------------------------------
   Handles the head (fonts, meta, favicon), drops in the VariantNav switcher,
   wires one shared reveal-on-scroll observer, and exposes the document body via
   <slot>. Each variant owns its body markup, its own CSS file, and its own JS.

   Loads tokens.css for the type system (IBM Plex families + Krapka @font-face +
   the studio palette custom properties) so variants can read --accent etc. and
   reuse the pixel font. Variants override the warm-paper defaults by scoping
   their CSS under the body class, e.g. `.v2 { background:#0a0a0e; }`.

   Conventions for variant pages:
     bodyClass="vN"   -> root selector .vN for all variant CSS
     an element with id="main" for the skip link
*/
import '../styles/tokens.css';
import VariantNav from '../components/variants/VariantNav.astro';

interface Props {
  n: number;
  title?: string;
  description?: string;
  themeColor?: string;
  bodyClass?: string;
}
const {
  n,
  title = 'Antonín Kindl - small software, made to fit',
  description = 'Small custom software by Antonín Kindl, alongside the art studio at kindl.work. A tool the exact size of your task.',
  themeColor = '#f4f1ea',
  bodyClass = '',
} = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content={themeColor} />
    {/* Exploration routes: keep them out of search while we choose. */}
    <meta name="robots" content="noindex, nofollow" />

    <link rel="icon" href={base + 'favicon.svg'} type="image/svg+xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,500;0,600;1,400&family=IBM+Plex+Serif:ital,wght@0,400;0,600;1,400&family=IBM+Plex+Sans:wght@400;500;600&display=swap"
    />

    <title>{title}</title>
  </head>
  <body class={bodyClass}>
    <a class="skip-link" href="#main">Skip to content</a>
    <slot />
    <VariantNav current={n} />

    {/* One shared reveal-on-scroll observer for any [data-reveal] element. */}
    <script is:inline>
      (function () {
        var els = document.querySelectorAll('[data-reveal]');
        if (!('IntersectionObserver' in window) || !els.length) {
          els.forEach(function (e) { e.classList.add('is-in'); });
          return;
        }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) { e.target.classList.add('is-in'); io.unobserve(e.target); }
          });
        }, { threshold: 0.14, rootMargin: '0px 0px -8% 0px' });
        els.forEach(function (e) { io.observe(e); });
      }());
    </script>

    <style is:global>
      .skip-link {
        position: absolute; left: -9999px; top: 0;
        background: #17150f; color: #f4f1ea; padding: 8px 12px; z-index: 10000;
        font-family: 'IBM Plex Mono', monospace; font-size: 12px;
      }
      .skip-link:focus { left: 8px; top: 8px; }
      [data-reveal] {
        opacity: 0; transform: translateY(14px);
        transition: opacity 0.6s cubic-bezier(0, 0, 0.2, 1), transform 0.6s cubic-bezier(0, 0, 0.2, 1);
      }
      [data-reveal].is-in { opacity: 1; transform: none; }
      @media (prefers-reduced-motion: reduce) {
        [data-reveal] { opacity: 1 !important; transform: none !important; }
      }
    </style>
  </body>
</html>
