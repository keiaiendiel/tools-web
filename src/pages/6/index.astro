---
import VariantBase from '../../layouts/VariantBase.astro';
import { content } from '../../i18n/content.js';
import '../../styles/variants/v6.css';
const c = content.en;

/* PROBE - variant 06.
   The landing is an intake, not a brochure. From load it fills the screen and
   quietly asks the visitor what software they keep building by hand, one short
   step at a time. Each answer drops a labelled node into a living physarum
   (slime-mold) network on the background; the network grows toward the nodes and
   connects them, building toward a single proposed tool at the close.

   The step sequence, the answer-to-tool mapping and the synthesis are built in
   v6.js (one source of truth). This page is the shell: the fixed physarum
   canvas, the atmosphere layers, the node host, and the intake container the
   controller fills. A <noscript> block carries the real message and a link so the
   page still reads with scripting off. */
---
<VariantBase
  n={6}
  title="Antonín Kindl - what do you keep doing by hand?"
  description="A small intake from Antonín Kindl: tell me the software you keep building by hand, and I propose the tool the exact size of your task. Alongside the art studio at kindl.work."
  themeColor="#07080d"
  bodyClass="v6"
>
  <!-- The atmosphere. Decorative; real copy is never trapped inside the canvas. -->
  <canvas id="probe-field" class="v6-field" aria-hidden="true"></canvas>
  <div class="v6-vignette" aria-hidden="true"></div>
  <div class="v6-grain" aria-hidden="true"></div>

  <main id="main" class="v6">

    <!-- The labelled nodes the controller drops over the field, one per answer. -->
    <div class="v6-nodes" data-nodes aria-hidden="true"></div>

    <!-- The intake. The controller renders one question at a time into [data-step]. -->
    <section class="v6-intake" data-intake aria-label="A short intake from the studio">
      <div class="v6-top">
        <p class="v6-eyebrow">
          <span class="v6-pix">06</span> probe <span class="v6-sep">/</span> tools.kindl.work
        </p>
        <div class="v6-trace" data-trace aria-hidden="true"></div>
      </div>

      <!-- Filled by v6.js. Empty until the controller boots. -->
      <div data-step>
        <noscript>
          <p class="v6-kicker">probe</p>
          <h1 class="v6-q">What do you keep doing by hand?</h1>
          <p class="v6-hint">
            I build small software shaped to one task at a time, alongside the art
            studio at kindl.work. Tell me the tool you wish existed and I make it.
          </p>
          <div class="v6-links" style="margin-top:24px;border-top:0;padding-top:0;">
            <a class="v6-link v6-link--primary" href="https://kindl.work" target="_blank" rel="noopener">
              start a tool <span aria-hidden="true">↗</span>
            </a>
            <a class="v6-link" href="https://kindl.work" target="_blank" rel="noopener">
              the art studio <span aria-hidden="true">↗</span>
            </a>
          </div>
        </noscript>
      </div>
    </section>

  </main>

  <script>import '../../scripts/variants/v6.js';</script>
</VariantBase>
