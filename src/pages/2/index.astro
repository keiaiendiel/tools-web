---
import VariantBase from '../../layouts/VariantBase.astro';
import { vcopy } from '../../i18n/variant-copy.js';
import '../../styles/variants/v2.css';
const c = vcopy[2];
const trades = Object.keys(c.fields.examples);
---
<VariantBase
  n={2}
  title="Antonin Kindl - small software, made to fit"
  description="A terminal you can type into. Small custom software by Antonin Kindl, alongside the art studio at kindl.work. A tool the exact size of your task."
  themeColor="#0a0a0e"
  bodyClass="v2"
>
  <!-- living ASCII field, decorative -->
  <div class="v2-field" aria-hidden="true"><canvas></canvas></div>
  <!-- faint CRT scanline + bloom, decorative -->
  <div class="v2-crt" aria-hidden="true"></div>

  <main id="main" class="v2">
    <div class="v2-shell">

      <header class="v2-crumb v2-rise">
        <span class="dot" aria-hidden="true"></span>
        <span><span class="host">kindl.work</span> / small-software bench</span>
        <span class="uptime" aria-hidden="true">live</span>
      </header>

      <!-- The terminal window. The prompt row is baked in; boot text and command
           output are appended by JS as real selectable text. The static
           <noscript>-style fallback below carries the full copy when JS is off. -->
      <section class="v2-term v2-rise" aria-label="Interactive terminal">
        <div class="v2-bar">
          <span class="lights" aria-hidden="true"><i></i><i></i><i></i></span>
          <span class="title">bench.sh</span>
          <span class="badge" aria-hidden="true">online</span>
        </div>

        <div class="v2-log" role="log" aria-live="polite" aria-label="Terminal output">
          <!-- live prompt: JS reveals it after the boot sequence -->
          <div class="v2-prompt">
            <span class="pr" aria-hidden="true">kindl.work:~$</span>
            <label class="v2-input-wrap">
              <span class="visually-hidden" style="position:absolute;left:-9999px;">Type a command</span>
              <input
                class="v2-input"
                type="text"
                autocomplete="off"
                autocapitalize="off"
                autocorrect="off"
                spellcheck="false"
                inputmode="text"
                aria-label="Type a command: help, bench, ships, fields, order, about, kindl, clear"
              />
              <span class="v2-caret" aria-hidden="true"></span>
            </label>
          </div>
        </div>
      </section>

      <!-- Command chips: the primary control on touch, and discoverability for all.
           Real buttons, keyboard reachable, large tap targets. -->
      <nav class="v2-chips v2-rise" aria-label="Run a command">
        <span class="lab">run</span>
        <button class="v2-chip" data-cmd="help" type="button">help</button>
        <button class="v2-chip" data-cmd="bench" type="button">bench</button>
        <button class="v2-chip" data-cmd="ships" type="button">ships</button>
        <button class="v2-chip" data-cmd="fields" type="button">fields</button>
        <button class="v2-chip" data-cmd="order" type="button">order</button>
        <button class="v2-chip" data-cmd="about" type="button">about</button>
        <button class="v2-chip is-ext" data-cmd="kindl" type="button">kindl</button>
      </nav>

      <!-- The two CTAs, quiet and tasteful. Single contact surface for now. -->
      <div class="v2-cta v2-rise">
        <a class="v2-btn v2-btn--primary" href="https://kindl.work" target="_blank" rel="noopener">
          {c.order.cta1} <span class="arr" aria-hidden="true">&#8599;</span>
        </a>
        <a class="v2-btn v2-btn--ghost" href="https://kindl.work" target="_blank" rel="noopener">
          {c.order.cta2} <span class="arr" aria-hidden="true">&#8599;</span>
        </a>
      </div>

      <footer class="v2-foot v2-rise">
        <div class="v2-foot__sig">
          {c.footer.sig1}<b>{c.footer.sigBold}</b>{c.footer.sig2}
        </div>
        <div>
          <h5>{c.footer.studio}</h5>
          <ul>
            <li><a href="https://kindl.work" target="_blank" rel="noopener">kindl.work &#8599;</a></li>
            <li><b>{c.footer.role}</b></li>
            <li>{c.footer.place}</li>
          </ul>
        </div>
        <div>
          <h5>{c.footer.now}</h5>
          <ul>
            <li>{c.hero.meta[0]}</li>
            <li>{c.hero.meta[1]}</li>
            <li>{c.hero.meta[2]}</li>
          </ul>
        </div>
      </footer>

      <!-- =================================================================
           No-JS / screen-reader fallback. Carries the full copy as real,
           selectable text. Hidden once the terminal boots (JS sets a class on
           <html>); shown otherwise so the page is never empty of content.
      ================================================================== -->
      <section class="v2-static" aria-label="Full content">
        <h2 class="v2-banner">{c.hero.claim1}<span class="ln2">{c.hero.claim2}</span></h2>
        <p class="v2-banner-sub">{c.hero.sub}</p>
        <p class="v2-soft">{c.hero.intro}</p>

        <h3 class="v2-h">{c.how.h}</h3>
        <p class="v2-soft">{c.how.p1}</p>
        <p class="v2-soft">{c.how.p2}</p>

        <h3 class="v2-h">{c.bench.h}</h3>
        <p class="v2-soft">{c.bench.intro}</p>
        <ul>
          {c.bench.lines.map((ln) => (
            <li><b class="v2-h">{ln.k}</b> {ln.d}</li>
          ))}
        </ul>
        <ul>
          {c.bench.items.map((it) => (
            <li><span class="nm">{it.nm}</span> <span class="who">{it.who}</span></li>
          ))}
        </ul>

        <h3 class="v2-h">{c.fields.h}</h3>
        <p class="v2-soft">{c.fields.intro}</p>
        {trades.map((trade) => (
          <div>
            <h4 class="v2-em">{trade}</h4>
            <ul>
              {c.fields.examples[trade].map(([name, who]) => (
                <li><span class="nm">{name}</span> <span class="who">{who}</span></li>
              ))}
            </ul>
          </div>
        ))}

        <h3 class="v2-h">{c.band.line1} {c.band.line2}</h3>
        <p class="v2-soft">{c.band.sub}</p>

        <h3 class="v2-h">{c.ships.h}</h3>
        <ul>
          {c.ships.items.map((s) => (
            <li>
              <span class="no">{s.no}</span> <b class="snm">{s.nm}</b> <span class="who">{s.who}</span>
              <span class="what">{s.what}</span>
            </li>
          ))}
        </ul>

        <h3 class="v2-h">{c.order.h}</h3>
        <ul>
          {c.order.cols.map((col) => (
            <li><b class="t">{col.t}</b> <span class="px">{col.px}</span> <span class="v2-way-d">{col.d}</span></li>
          ))}
        </ul>
      </section>

    </div>
  </main>

  <style is:global>
    /* The static fallback is real content; hide it only when JS has booted the
       terminal (the script adds .v2-js to <html>). Keeps copy selectable and
       present for no-JS and assistive tech. */
    .v2-static { color: var(--t-ink-soft); display: grid; gap: 14px; padding-top: 8px; }
    .v2-static h3 { margin: 18px 0 4px; }
    .v2-static h4 { margin: 10px 0 2px; }
    .v2-static ul { display: grid; gap: 4px; }
    .v2-static .who { color: var(--t-ink-faint); margin-left: 8px; }
    .v2-static .px { color: var(--t-amber); margin-left: 8px; }
    html.v2-js .v2-static { display: none; }
  </style>

  <script is:inline>
    /* Flag JS as available before paint so the static fallback never flashes
       for the common (JS-on) case. The module script then renders the terminal. */
    document.documentElement.classList.add('v2-js');
  </script>

  <script>
    import '../../scripts/variants/v2.js';
  </script>
</VariantBase>
