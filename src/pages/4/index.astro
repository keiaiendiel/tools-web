---
/* =============================================================================
   /4 - "SCHEMATIC"
   -----------------------------------------------------------------------------
   The studio rendered as a pen-plotter engineering drawing. A light cool
   drafting sheet carrying a faint draftsman grid; structure in ink hairlines and
   one studio blue. Dimension lines with arrowheads annotate the layout, a fixed
   title block sits bottom-right like a real sheet, and three small schematics
   draw themselves on scroll (stroke-dasharray animated in v4.js).

   All copy is real selectable text. Every decorative SVG is aria-hidden. Scoped
   under .v4 (CSS) and the body class .v4. House rule: no em dashes anywhere.
============================================================================= */
import VariantBase from '../../layouts/VariantBase.astro';
import { vcopy } from '../../i18n/variant-copy.js';
import '../../styles/variants/v4.css';
const c = vcopy[4];
---
<VariantBase
  n={4}
  title="Antonin Kindl - small software, made to fit"
  description="Small custom software by Antonin Kindl, drawn to fit one task. A pen-plotter engineering sheet of the studio bench: generators, AV and event calculators, computer-vision and installation utilities, alongside the art studio at kindl.work."
  themeColor="#eef0ec"
  bodyClass="v4"
>
  <main id="main" class="v4">
    {/* drafting grid sheet, fixed behind everything, decorative */}
    <div class="v4-sheet" aria-hidden="true">
      <div class="v4-grid"></div>
      <div class="v4-grid v4-grid--coarse"></div>
      <div class="v4-vignette"></div>
    </div>

    {/* the live crosshair that tracks the pointer over the hero; decorative */}
    <div class="v4-crosshair" aria-hidden="true" data-crosshair>
      <span class="v4-crosshair__v"></span>
      <span class="v4-crosshair__h"></span>
      <span class="v4-crosshair__read" data-cross-read>X 000.0  Y 000.0</span>
    </div>

    <div class="v4-doc">

      {/* ===================================================================
         HERO - the claim bracketed and measured
      =================================================================== */}
      <header class="v4-hero" data-hero>
        <p class="v4-eyebrow">
          <span class="v4-eyebrow__tag">DWG</span>
          <span class="v4-eyebrow__txt">small software / made to fit</span>
        </p>

        <div class="v4-claimwrap">
          {/* left vertical dimension marking the claim height */}
          <span class="v4-dim v4-dim--vert" aria-hidden="true">
            <span class="v4-dim__line"></span>
            <span class="v4-dim__num pix">144</span>
          </span>

          <h1 class="v4-claim">
            <span class="v4-claim__l1">{c.hero.claim1}</span>
            <span class="v4-claim__l2">{c.hero.claim2}</span>
          </h1>

          {/* top horizontal dimension bracketing the claim width */}
          <span class="v4-dim v4-dim--horiz" aria-hidden="true">
            <span class="v4-dim__line"></span>
            <span class="v4-dim__num pix">1:1</span>
          </span>
        </div>

        <p class="v4-sub">{c.hero.sub}</p>

        <div class="v4-herofoot">
          <p class="v4-intro body">{c.hero.intro}</p>

          {/* leader line + meta tags as a parts callout */}
          <ul class="v4-meta" aria-label="notes">
            {c.hero.meta.map((m, i) => (
              <li class="v4-meta__row">
                <span class="v4-meta__no pix">{String(i + 1).padStart(2, '0')}</span>
                <span class="v4-meta__lead" aria-hidden="true"></span>
                <span class="v4-meta__txt">{m}</span>
              </li>
            ))}
          </ul>
        </div>
      </header>

      {/* ===================================================================
         HOW - "a tool the exact size of your task" + first schematic
      =================================================================== */}
      <section class="v4-sec v4-how" aria-labelledby="v4-how-h">
        <div class="v4-sechead" data-reveal>
          <span class="v4-secmark pix">A</span>
          <h2 class="v4-h2" id="v4-how-h">{c.how.h}</h2>
        </div>

        <div class="v4-how__grid">
          <div class="v4-how__text" data-reveal>
            <p class="body">{c.how.p1}</p>
            <p class="body">{c.how.p2}</p>
            <p class="v4-cap">{c.how.cap}</p>
          </div>

          {/* SCHEMATIC 1 - Design to tool flow diagram (draws itself) */}
          <figure class="v4-fig" data-reveal>
            <figcaption class="v4-fig__cap">FIG. A1 / DESIGN -&gt; TOOL</figcaption>
            <svg
              class="v4-svg"
              viewBox="0 0 320 220"
              role="img"
              aria-label="Flow diagram: a finished design becomes a generator the client runs alone."
              data-draw
            >
              <g class="v4-stroke" fill="none" stroke="currentColor" stroke-width="1.1" vector-effect="non-scaling-stroke">
                {/* node 1: design */}
                <rect class="v4-d" x="22" y="40" width="86" height="46" rx="2" data-len="264"/>
                <line class="v4-d" x1="34" y1="58" x2="96" y2="58" data-len="62"/>
                <line class="v4-d" x1="34" y1="68" x2="84" y2="68" data-len="50"/>
                {/* arrow design -> rule */}
                <line class="v4-d" x1="108" y1="63" x2="148" y2="63" data-len="40"/>
                <polyline class="v4-d" points="142,59 150,63 142,67" data-len="18"/>
                {/* node 2: the rule / template */}
                <rect class="v4-d" x="150" y="40" width="60" height="46" rx="2" data-len="212"/>
                <line class="v4-d" x1="160" y1="50" x2="200" y2="76" data-len="48"/>
                <line class="v4-d" x1="160" y1="63" x2="200" y2="63" data-len="40"/>
                {/* arrow rule -> tool */}
                <line class="v4-d" x1="210" y1="63" x2="252" y2="63" data-len="42"/>
                <polyline class="v4-d" points="246,59 254,63 246,67" data-len="18"/>
                {/* node 3: the generator (a fanned stack of outputs) */}
                <rect class="v4-d" x="262" y="34" width="44" height="46" rx="2" data-len="180"/>
                <rect class="v4-d" x="256" y="40" width="44" height="46" rx="2" data-len="180"/>
                <rect class="v4-d" x="250" y="46" width="44" height="46" rx="2" data-len="180"/>
                {/* recurrence loop: tool feeds back to rule */}
                <path class="v4-d" d="M272 92 q 0 40 -90 40 q -90 0 -90 -40" data-len="392"/>
                <polyline class="v4-d" points="96,128 88,124 88,132" data-len="18"/>
              </g>
              <g class="v4-dots">
                <circle cx="108" cy="63" r="2.4"/>
                <circle cx="150" cy="63" r="2.4"/>
                <circle cx="252" cy="63" r="2.4"/>
                <circle cx="92" cy="128" r="2.4"/>
              </g>
              <g class="v4-svglabel">
                <text x="65" y="104">SOURCE</text>
                <text x="180" y="104">RULE</text>
                <text x="276" y="108">N OUT</text>
                <text x="120" y="150">RUN ALONE, ON BRAND</text>
              </g>
            </svg>
          </figure>
        </div>
      </section>

      {/* ===================================================================
         BENCH - the parts list / BOM table
      =================================================================== */}
      <section class="v4-sec v4-bench" aria-labelledby="v4-bench-h">
        <div class="v4-sechead" data-reveal>
          <span class="v4-secmark pix">B</span>
          <h2 class="v4-h2" id="v4-bench-h">{c.bench.h}</h2>
        </div>
        <p class="v4-secintro body" data-reveal>{c.bench.intro}</p>

        {/* the four lines as a numbered legend */}
        <ul class="v4-lines" data-reveal>
          {c.bench.lines.map((ln, i) => (
            <li class="v4-line">
              <span class="v4-line__no pix">{String(i + 1).padStart(2, '0')}</span>
              <span class="v4-line__k">{ln.k}</span>
              <span class="v4-line__d">{ln.d}</span>
            </li>
          ))}
        </ul>

        {/* the 18 tools as a bill of materials */}
        <div class="v4-bom" data-reveal>
          <div class="v4-bom__head" aria-hidden="true">
            <span class="v4-bom__c v4-bom__c--no">ITEM</span>
            <span class="v4-bom__c v4-bom__c--nm">DESCRIPTION</span>
            <span class="v4-bom__c v4-bom__c--who">FOR</span>
          </div>
          <ol class="v4-bom__body">
            {c.bench.items.map((it, i) => (
              <li class="v4-bom__row">
                <span class="v4-bom__c v4-bom__c--no pix tnum">{String(i + 1).padStart(2, '0')}</span>
                <span class="v4-bom__c v4-bom__c--nm">{it.nm}</span>
                <span class="v4-bom__c v4-bom__c--who">{it.who}</span>
              </li>
            ))}
          </ol>
        </div>
      </section>

      {/* ===================================================================
         FIELDS - by trade, with the second schematic (pose to OSC)
      =================================================================== */}
      <section class="v4-sec v4-fields" aria-labelledby="v4-fields-h">
        <div class="v4-sechead" data-reveal>
          <span class="v4-secmark pix">C</span>
          <h2 class="v4-h2" id="v4-fields-h">{c.fields.h}</h2>
        </div>
        <p class="v4-secintro body" data-reveal>{c.fields.intro}</p>

        <div class="v4-fields__grid">
          <div class="v4-trades" data-reveal>
            {Object.entries(c.fields.examples).map(([trade, rows]) => (
              <details class="v4-trade">
                <summary class="v4-trade__sum">
                  <span class="v4-trade__nm">{trade}</span>
                  <span class="v4-trade__count pix tnum">{String(rows.length).padStart(2, '0')}</span>
                  <span class="v4-trade__mark" aria-hidden="true">+</span>
                </summary>
                <ul class="v4-trade__list">
                  {rows.map(([name, who]) => (
                    <li class="v4-trade__row">
                      <span class="v4-trade__rnm">{name}</span>
                      <span class="v4-trade__dot" aria-hidden="true"></span>
                      <span class="v4-trade__who">{who}</span>
                    </li>
                  ))}
                </ul>
              </details>
            ))}
          </div>

          {/* SCHEMATIC 2 - pose-to-OSC signal flow */}
          <figure class="v4-fig v4-fig--sticky" data-reveal>
            <figcaption class="v4-fig__cap">FIG. C1 / POSE -&gt; OSC</figcaption>
            <svg
              class="v4-svg"
              viewBox="0 0 280 300"
              role="img"
              aria-label="Signal flow: camera reads a body, a model extracts keypoints, the keypoints stream out as OSC."
              data-draw
            >
              <g class="v4-stroke" fill="none" stroke="currentColor" stroke-width="1.1" vector-effect="non-scaling-stroke">
                {/* a stick body: head, torso, limbs */}
                <circle class="v4-d" cx="70" cy="44" r="13" data-len="82"/>
                <line class="v4-d" x1="70" y1="57" x2="70" y2="118" data-len="61"/>
                <line class="v4-d" x1="70" y1="74" x2="44" y2="100" data-len="37"/>
                <line class="v4-d" x1="70" y1="74" x2="96" y2="100" data-len="37"/>
                <line class="v4-d" x1="70" y1="118" x2="50" y2="160" data-len="46"/>
                <line class="v4-d" x1="70" y1="118" x2="92" y2="160" data-len="47"/>
                {/* camera frame around the body */}
                <rect class="v4-d" x="24" y="22" width="96" height="160" rx="2" data-len="512"/>
                <line class="v4-d" x1="120" y1="34" x2="134" y2="28" data-len="15"/>
                <line class="v4-d" x1="120" y1="170" x2="134" y2="176" data-len="15"/>
                {/* bus from camera to model */}
                <line class="v4-d" x1="120" y1="100" x2="168" y2="100" data-len="48"/>
                <polyline class="v4-d" points="162,96 170,100 162,104" data-len="18"/>
                {/* model node */}
                <rect class="v4-d" x="170" y="78" width="86" height="44" rx="2" data-len="260"/>
                {/* keypoint constellation inside model */}
                <path class="v4-d" d="M186 100 L202 90 L218 102 L234 92 L246 104" data-len="76"/>
                {/* fan-out lines down to OSC channels */}
                <line class="v4-d" x1="213" y1="122" x2="213" y2="150" data-len="28"/>
                <line class="v4-d" x1="186" y1="150" x2="240" y2="150" data-len="54"/>
                <line class="v4-d" x1="186" y1="150" x2="186" y2="232" data-len="82"/>
                <line class="v4-d" x1="213" y1="150" x2="213" y2="232" data-len="82"/>
                <line class="v4-d" x1="240" y1="150" x2="240" y2="232" data-len="82"/>
                {/* three OSC channel pads */}
                <rect class="v4-d" x="170" y="232" width="32" height="22" rx="1" data-len="108"/>
                <rect class="v4-d" x="197" y="232" width="32" height="22" rx="1" data-len="108"/>
                <rect class="v4-d" x="224" y="232" width="32" height="22" rx="1" data-len="108"/>
              </g>
              <g class="v4-dots">
                <circle cx="120" cy="100" r="2.4"/>
                <circle cx="170" cy="100" r="2.4"/>
                <circle cx="186" cy="100" r="2"/>
                <circle cx="202" cy="90" r="2"/>
                <circle cx="218" cy="102" r="2"/>
                <circle cx="234" cy="92" r="2"/>
                <circle cx="246" cy="104" r="2"/>
                <circle cx="213" cy="150" r="2.4"/>
              </g>
              <g class="v4-svglabel">
                <text x="38" y="200">CAMERA</text>
                <text x="180" y="72">MODEL / KEYPOINTS</text>
                <text x="170" y="270">/x</text>
                <text x="197" y="270">/y</text>
                <text x="224" y="270">/z</text>
                <text x="170" y="284">OSC OUT</text>
              </g>
            </svg>
          </figure>
        </div>

        <p class="v4-fields__foot faint" data-reveal>Ten trades on file. Tell me yours and I draw one to it.</p>
      </section>

      {/* ===================================================================
         BAND - the quiet declaration, dimensioned
      =================================================================== */}
      <section class="v4-band" aria-label="summary" data-reveal>
        <span class="v4-band__bracket v4-band__bracket--l" aria-hidden="true"></span>
        <div class="v4-band__inner">
          <p class="v4-band__line">{c.band.line1}</p>
          <p class="v4-band__line v4-band__line--em">{c.band.line2}</p>
          <p class="v4-band__sub">{c.band.sub}</p>
        </div>
        <span class="v4-band__bracket v4-band__bracket--r" aria-hidden="true"></span>
      </section>

      {/* ===================================================================
         SHIPS - three assemblies, with the third schematic (LED pitch + power)
      =================================================================== */}
      <section class="v4-sec v4-ships" aria-labelledby="v4-ships-h">
        <div class="v4-sechead" data-reveal>
          <span class="v4-secmark pix">D</span>
          <h2 class="v4-h2" id="v4-ships-h">{c.ships.h}</h2>
        </div>

        <div class="v4-assemblies">
          {c.ships.items.map((s) => (
            <article class="v4-asm" data-reveal>
              <div class="v4-asm__head">
                <span class="v4-asm__no pix tnum">{s.no}</span>
                <h3 class="v4-asm__nm">{s.nm}</h3>
              </div>
              <p class="v4-asm__what body">{s.what}</p>
              <p class="v4-asm__who">
                <span class="v4-asm__leader" aria-hidden="true"></span>
                {s.who}
              </p>
            </article>
          ))}
        </div>

        {/* SCHEMATIC 3 - LED pitch + power, a tiny circuit */}
        <figure class="v4-fig v4-fig--wide" data-reveal>
          <figcaption class="v4-fig__cap">FIG. D1 / LED PITCH + POWER</figcaption>
          <svg
            class="v4-svg"
            viewBox="0 0 520 180"
            role="img"
            aria-label="Circuit: a supply feeds an LED strip across a measured pitch, with current summed at the load."
            data-draw
          >
            <g class="v4-stroke" fill="none" stroke="currentColor" stroke-width="1.1" vector-effect="non-scaling-stroke">
              {/* supply: a battery symbol on the left */}
              <line class="v4-d" x1="40" y1="60" x2="40" y2="120" data-len="60"/>
              <line class="v4-d" x1="24" y1="74" x2="56" y2="74" data-len="32"/>
              <line class="v4-d" x1="32" y1="86" x2="48" y2="86" data-len="16"/>
              <line class="v4-d" x1="24" y1="98" x2="56" y2="98" data-len="32"/>
              <line class="v4-d" x1="32" y1="110" x2="48" y2="110" data-len="16"/>
              {/* top rail out from supply */}
              <line class="v4-d" x1="40" y1="60" x2="40" y2="40" data-len="20"/>
              <line class="v4-d" x1="40" y1="40" x2="470" y2="40" data-len="430"/>
              {/* bottom return rail */}
              <line class="v4-d" x1="40" y1="120" x2="40" y2="140" data-len="20"/>
              <line class="v4-d" x1="40" y1="140" x2="470" y2="140" data-len="430"/>
              {/* the LED strip: five diode cells across the pitch */}
              <line class="v4-d" x1="120" y1="40" x2="120" y2="64" data-len="24"/>
              <polyline class="v4-d" points="110,64 130,64 120,82 110,64" data-len="48"/>
              <line class="v4-d" x1="110" y1="84" x2="130" y2="84" data-len="20"/>
              <line class="v4-d" x1="120" y1="84" x2="120" y2="140" data-len="56"/>

              <line class="v4-d" x1="200" y1="40" x2="200" y2="64" data-len="24"/>
              <polyline class="v4-d" points="190,64 210,64 200,82 190,64" data-len="48"/>
              <line class="v4-d" x1="190" y1="84" x2="210" y2="84" data-len="20"/>
              <line class="v4-d" x1="200" y1="84" x2="200" y2="140" data-len="56"/>

              <line class="v4-d" x1="280" y1="40" x2="280" y2="64" data-len="24"/>
              <polyline class="v4-d" points="270,64 290,64 280,82 270,64" data-len="48"/>
              <line class="v4-d" x1="270" y1="84" x2="290" y2="84" data-len="20"/>
              <line class="v4-d" x1="280" y1="84" x2="280" y2="140" data-len="56"/>

              <line class="v4-d" x1="360" y1="40" x2="360" y2="64" data-len="24"/>
              <polyline class="v4-d" points="350,64 370,64 360,82 350,64" data-len="48"/>
              <line class="v4-d" x1="350" y1="84" x2="370" y2="84" data-len="20"/>
              <line class="v4-d" x1="360" y1="84" x2="360" y2="140" data-len="56"/>

              <line class="v4-d" x1="440" y1="40" x2="440" y2="64" data-len="24"/>
              <polyline class="v4-d" points="430,64 450,64 440,82 430,64" data-len="48"/>
              <line class="v4-d" x1="430" y1="84" x2="450" y2="84" data-len="20"/>
              <line class="v4-d" x1="440" y1="84" x2="440" y2="140" data-len="56"/>

              {/* pitch dimension between two LEDs along the top */}
              <line class="v4-d" x1="120" y1="22" x2="200" y2="22" data-len="80"/>
              <polyline class="v4-d" points="126,18 120,22 126,26" data-len="12"/>
              <polyline class="v4-d" points="194,18 200,22 194,26" data-len="12"/>
              <line class="v4-d" x1="120" y1="16" x2="120" y2="34" data-len="18"/>
              <line class="v4-d" x1="200" y1="16" x2="200" y2="34" data-len="18"/>
            </g>
            <g class="v4-dots">
              <circle cx="120" cy="40" r="2.4"/>
              <circle cx="200" cy="40" r="2.4"/>
              <circle cx="280" cy="40" r="2.4"/>
              <circle cx="360" cy="40" r="2.4"/>
              <circle cx="440" cy="40" r="2.4"/>
              <circle cx="120" cy="140" r="2.4"/>
              <circle cx="200" cy="140" r="2.4"/>
              <circle cx="280" cy="140" r="2.4"/>
              <circle cx="360" cy="140" r="2.4"/>
              <circle cx="440" cy="140" r="2.4"/>
            </g>
            <g class="v4-svglabel">
              <text x="20" y="164">V+ / GND</text>
              <text x="150" y="14">PITCH p</text>
              <text x="470" y="44" class="v4-svglabel--end">SUM I = n . i</text>
            </g>
          </svg>
        </figure>
      </section>

      {/* ===================================================================
         ORDER - the spec / revision table
      =================================================================== */}
      <section class="v4-sec v4-order" aria-labelledby="v4-order-h">
        <div class="v4-sechead" data-reveal>
          <span class="v4-secmark pix">E</span>
          <h2 class="v4-h2" id="v4-order-h">{c.order.h}</h2>
        </div>

        <div class="v4-spec" data-reveal>
          <div class="v4-spec__head" aria-hidden="true">
            <span class="v4-spec__c v4-spec__c--rev">REV</span>
            <span class="v4-spec__c v4-spec__c--t">WAY</span>
            <span class="v4-spec__c v4-spec__c--px">PRICE</span>
            <span class="v4-spec__c v4-spec__c--d">NOTE</span>
          </div>
          {c.order.cols.map((col, i) => (
            <div class="v4-spec__row">
              <span class="v4-spec__c v4-spec__c--rev pix tnum">{String.fromCharCode(65 + i)}</span>
              <span class="v4-spec__c v4-spec__c--t">{col.t}</span>
              <span class="v4-spec__c v4-spec__c--px tnum">{col.px}</span>
              <span class="v4-spec__c v4-spec__c--d">{col.d}</span>
            </div>
          ))}
        </div>

        <div class="v4-cta" data-reveal>
          <a class="v4-cta__a v4-cta__a--prime" href="https://kindl.work" target="_blank" rel="noopener">
            {c.order.cta1} <span aria-hidden="true">&#8599;</span>
          </a>
          <a class="v4-cta__a" href="https://kindl.work" target="_blank" rel="noopener">
            {c.order.cta2} <span aria-hidden="true">&#8599;</span>
          </a>
        </div>
      </section>

      {/* ===================================================================
         FOOTER - the signature row
      =================================================================== */}
      <footer class="v4-footer" data-reveal>
        <p class="v4-footer__sig">
          {c.footer.sig1}<strong>{c.footer.sigBold}</strong>{c.footer.sig2}
        </p>
        <dl class="v4-footer__meta">
          <div class="v4-footer__pair">
            <dt>{c.footer.studio}</dt>
            <dd><a href="https://kindl.work" target="_blank" rel="noopener">kindl.work <span aria-hidden="true">&#8599;</span></a></dd>
          </div>
          <div class="v4-footer__pair">
            <dt>{c.footer.now}</dt>
