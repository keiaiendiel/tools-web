---
import VariantBase from '../../layouts/VariantBase.astro';
import { content } from '../../i18n/content.js';
import '../../styles/variants/v5.css';
const c = content.en;

/* FIELD - variant 05.
   A hand-written WebGL point-cloud typography field that you move through.
   Real, selectable copy lives in DOM panels layered over the GL atmosphere.
   The GL is the headline mechanism and the air; the panels carry the substance. */
const fields = Object.entries(c.fields.examples);
---
<VariantBase
  n={5}
  title="Antonín Kindl - small software, made to fit"
  description={c.description}
  themeColor="#07070c"
  bodyClass="v5"
>
  <!-- The atmosphere. Decorative; copy is never trapped inside it. -->
  <canvas id="field-gl" class="v5-field" aria-hidden="true"></canvas>
  <div class="v5-vignette" aria-hidden="true"></div>
  <div class="v5-grain" aria-hidden="true"></div>

  <!-- A tiny, reachable control for motion / sound-free toggle of the field. -->
  <button id="field-toggle" class="v5-toggle" type="button" aria-pressed="true">
    <span class="v5-toggle__dot" aria-hidden="true"></span>
    <span class="v5-toggle__label">field</span>
  </button>

  <main id="main" class="v5">

    <!-- 00 HERO ---------------------------------------------------------- -->
    <section class="v5-station" data-station="0" data-word="MADE">
      <div class="v5-panel v5-panel--hero">
        <p class="v5-eyebrow" data-reveal>
          <span class="v5-pix">05</span> field <span class="v5-sep">/</span> tools.kindl.work
        </p>
        <h1 class="v5-claim" data-reveal>
          <span class="v5-claim__l1">{c.hero.claim1}</span>
          <span class="v5-claim__l2">{c.hero.claim2}</span>
        </h1>
        <p class="v5-sub" data-reveal>{c.hero.sub}</p>
        <p class="v5-intro" data-reveal>{c.hero.intro}</p>
        <ul class="v5-meta" data-reveal>
          {c.hero.meta.map((m) => <li><span class="v5-meta__b" aria-hidden="true">+</span>{m}</li>)}
        </ul>
        <div class="v5-scrollcue" data-reveal aria-hidden="true">
          <span class="v5-scrollcue__line"></span>
          <span class="v5-scrollcue__txt">scroll to move through the field</span>
        </div>
      </div>
    </section>

    <!-- 01 HOW ----------------------------------------------------------- -->
    <section class="v5-station" data-station="1" data-word="TO">
      <div class="v5-panel v5-panel--how">
        <p class="v5-mark"><span class="v5-pix">01</span> the idea</p>
        <h2 class="v5-h2" data-reveal>{c.how.h}</h2>
        <p class="v5-p" data-reveal>{c.how.p1}</p>
        <p class="v5-p v5-p--muted" data-reveal>{c.how.p2}</p>
        <p class="v5-cap" data-reveal>{c.how.cap}</p>
      </div>
    </section>

    <!-- 02 BENCH --------------------------------------------------------- -->
    <section class="v5-station" data-station="2" data-word="FIT">
      <div class="v5-panel v5-panel--bench">
        <p class="v5-mark"><span class="v5-pix">02</span> {c.nav.bench}</p>
        <h2 class="v5-h2" data-reveal>{c.bench.h}</h2>
        <p class="v5-p" data-reveal>{c.bench.intro}</p>

        <ol class="v5-lines" data-reveal>
          {c.bench.lines.map((ln, i) => (
            <li class="v5-line">
              <span class="v5-line__n v5-pix">{String(i + 1).padStart(2, '0')}</span>
              <span class="v5-line__k">{ln.k}</span>
              <span class="v5-line__d">{ln.d}</span>
            </li>
          ))}
        </ol>

        <ul class="v5-items" data-reveal>
          {c.bench.items.map((it) => (
            <li class="v5-item">
              <span class="v5-item__nm">{it.nm}</span>
              <span class="v5-item__who">{it.who}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- 03 FIELDS -------------------------------------------------------- -->
    <section class="v5-station" data-station="3" data-word="BENCH">
      <div class="v5-panel v5-panel--fields">
        <p class="v5-mark"><span class="v5-pix">03</span> {c.nav.fields}</p>
        <h2 class="v5-h2" data-reveal>{c.fields.h}</h2>
        <p class="v5-p" data-reveal>{c.fields.intro}</p>

        <div class="v5-trades" data-reveal>
          <ul class="v5-trades__tabs" role="tablist" aria-label="Fields">
            {fields.map(([name], i) => (
              <li role="presentation">
                <button
                  class={'v5-trade' + (i === 0 ? ' is-on' : '')}
                  type="button"
                  role="tab"
                  aria-selected={i === 0 ? 'true' : 'false'}
                  data-trade={name}
                  id={'v5-tab-' + i}
                  aria-controls={'v5-panel-' + i}
                >{name}</button>
              </li>
            ))}
          </ul>
          <div class="v5-trades__body">
            {fields.map(([name, list], i) => (
              <ul
                class={'v5-trade-list' + (i === 0 ? ' is-on' : '')}
                role="tabpanel"
                id={'v5-panel-' + i}
                aria-labelledby={'v5-tab-' + i}
                data-trade-list={name}
                hidden={i !== 0}
              >
                {list.map(([nm, who]) => (
                  <li class="v5-trade-row">
                    <span class="v5-trade-row__nm">{nm}</span>
                    <span class="v5-trade-row__who">{who}</span>
                  </li>
                ))}
              </ul>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- BAND ------------------------------------------------------------- -->
    <section class="v5-station v5-station--band" data-station="4" data-word="SHIP">
      <div class="v5-panel v5-panel--band">
        <p class="v5-band" data-reveal>
          <span class="v5-band__l">{c.band.line1}</span>
          <span class="v5-band__l v5-band__l--accent">{c.band.line2}</span>
        </p>
        <p class="v5-band__sub" data-reveal>{c.band.sub}</p>
      </div>
    </section>

    <!-- 04 SHIPS --------------------------------------------------------- -->
    <section class="v5-station" data-station="5" data-word="SHIP">
      <div class="v5-panel v5-panel--ships">
        <p class="v5-mark"><span class="v5-pix">04</span> ships first</p>
        <h2 class="v5-h2" data-reveal>{c.ships.h}</h2>
        <div class="v5-ships" data-reveal>
          {c.ships.items.map((it) => (
            <article class="v5-ship">
              <span class="v5-ship__no v5-pix">{it.no}</span>
              <h3 class="v5-ship__nm">{it.nm}</h3>
              <p class="v5-ship__what">{it.what}</p>
              <p class="v5-ship__who">{it.who}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- 05 ORDER --------------------------------------------------------- -->
    <section class="v5-station" data-station="6" data-word="FIT">
      <div class="v5-panel v5-panel--order">
        <p class="v5-mark"><span class="v5-pix">05</span> {c.nav.order}</p>
        <h2 class="v5-h2" data-reveal>{c.order.h}</h2>
        <div class="v5-cols" data-reveal>
          {c.order.cols.map((col, i) => (
            <article class="v5-col">
              <span class="v5-col__i v5-pix">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="v5-col__t">{col.t}</h3>
              <p class="v5-col__px">{col.px}</p>
              <p class="v5-col__d">{col.d}</p>
            </article>
          ))}
        </div>
        <div class="v5-cta" data-reveal>
          <a class="v5-cta__a v5-cta__a--primary" href="https://kindl.work" target="_blank" rel="noopener">
            {c.order.cta1} <span aria-hidden="true">↗</span>
          </a>
          <a class="v5-cta__a" href="https://kindl.work" target="_blank" rel="noopener">
            {c.order.cta2} <span aria-hidden="true">↗</span>
          </a>
        </div>
      </div>
    </section>

    <!-- FOOTER ----------------------------------------------------------- -->
    <footer class="v5-foot">
      <div class="v5-panel v5-panel--foot">
        <p class="v5-foot__sig" data-reveal>
          {c.footer.sig1}<b>{c.footer.sigBold}</b>{c.footer.sig2}
        </p>
        <dl class="v5-foot__cols" data-reveal>
          <div>
            <dt>{c.footer.studio}</dt>
            <dd><a href="https://kindl.work" target="_blank" rel="noopener">kindl.work ↗</a></dd>
          </div>
          <div>
            <dt>{c.footer.now}</dt>
            <dd>{c.footer.role}, {c.footer.place}</dd>
          </div>
        </dl>
      </div>
    </footer>

  </main>

  <script>
    import '../../scripts/variants/v5.js';
  </script>
</VariantBase>
