---
/* VariantNav - a small frosted switcher shared by the two alternate landings.
   Two readings of the same studio: /lab (for the terminal-minded) and /space
   (for the visual-minded), plus a way back to the main site and out to the art
   studio. Theme-agnostic frosted glass so it reads on either ground.
   `current` is the active page's n: 2 = lab, 3 = space. */
const { current = 0 } = Astro.props;
const base = import.meta.env.BASE_URL;
const items = [
  { n: 2, slug: 'lab', label: 'lab' },
  { n: 3, slug: 'space', label: 'space' },
];
---
<nav class="vnav" aria-label="Readings of the studio" data-vnav>
  <a class="vnav__home" href={base} title="The main site">home</a>
  <span class="vnav__sep" aria-hidden="true">/</span>
  <ul class="vnav__list">
    {items.map((it) => (
      <li>
        <a
          class={'vnav__n' + (it.n === current ? ' is-on' : '')}
          href={base + it.slug}
          aria-current={it.n === current ? 'page' : undefined}
        >{it.label}</a>
      </li>
    ))}
  </ul>
  <a class="vnav__ext" href="https://see.kindl.work" target="_blank" rel="noopener">kindl.work&nbsp;↗</a>
</nav>

<style>
  .vnav {
    position: fixed;
    left: 50%;
    bottom: 18px;
    transform: translateX(-50%);
    z-index: 9999;
    display: flex;
    align-items: center;
    gap: 11px;
    padding: 8px 15px;
    font-family: 'IBM Plex Mono', ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 12px;
    letter-spacing: 0.04em;
    background: rgba(16, 15, 20, 0.72);
    color: #e9e7df;
    border: 1px solid rgba(233, 231, 223, 0.16);
    border-radius: 3px;
    backdrop-filter: blur(12px) saturate(1.3);
    -webkit-backdrop-filter: blur(12px) saturate(1.3);
    box-shadow: 0 8px 34px rgba(0, 0, 0, 0.30);
  }
  .vnav a { color: #b6b2c2; text-decoration: none; transition: color 0.15s ease; }
  .vnav a:hover { color: #fff; }
  .vnav__sep { color: rgba(233, 231, 223, 0.28); }
  .vnav__home { color: #9a96a8; }
  .vnav__list { display: flex; gap: 12px; margin: 0; padding: 0; list-style: none; }
  .vnav__n { position: relative; padding-bottom: 2px; }
  .vnav__n.is-on { color: #fff; }
  .vnav__n.is-on::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: -1px;
    height: 2px;
    background: #6f66e6;
  }
  .vnav__ext {
    margin-left: 4px;
    padding-left: 11px;
    border-left: 1px solid rgba(233, 231, 223, 0.16);
    color: #9a96a8;
    white-space: nowrap;
  }
  @media (max-width: 540px) {
    .vnav { bottom: 10px; gap: 9px; padding: 7px 12px; font-size: 11px; }
    .vnav__ext { display: none; }
  }
  @media print { .vnav { display: none; } }
</style>
